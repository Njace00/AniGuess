<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#260B1C"
    tools:context=".MainActivity">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#A0A0A0"
        android:backgroundTint="#2F082F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/AniGuess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="@string/title"
            android:textColor="#AD00FF"
            android:textSize="25sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- CENTER IMAGE -->

    <TextView
        android:id="@+id/difficultytxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20sp"
        android:fontFamily="@font/aldrich"
        android:text="@string/easy"
        android:textColor="#FFFFFF"
        android:textSize="25sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topbar" />


    <!-- IMAGE TOP ROW -->


    <ImageView
        android:id="@+id/pic1"
        android:layout_width="0sp"
        android:layout_height="120dp"
        android:layout_margin="20sp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toStartOf="@id/pic2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/difficultytxt"
        android:src="@drawable/pic1" />

    <ImageView
        android:id="@+id/pic2"
        android:layout_width="0sp"
        android:layout_height="120dp"
        android:layout_margin="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/pic1"
        app:layout_constraintTop_toBottomOf="@id/difficultytxt"
        android:src="@drawable/pic2" />



    <!-- IMAGE BOTTOM ROW -->
    <ImageView
        android:id="@+id/pic3"
        android:layout_width="0sp"
        android:layout_height="120dp"
        android:layout_margin="20sp"
        app:layout_constraintEnd_toStartOf="@id/pic4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pic1"
        android:src="@drawable/pic3" />


    <ImageView
        android:id="@+id/pic4"
        android:layout_width="0sp"
        android:layout_height="120dp"
        android:layout_margin="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/pic3"
        app:layout_constraintTop_toBottomOf="@id/pic2"
        android:src="@drawable/pic4" />

    <!-- CHOICES -->
    <View
        android:id="@+id/hr"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:background="#ffffff"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pic4" />

    <!-- TOP ROW CHOICES -->
    <Button
        android:id="@+id/choice1"
        android:layout_width="0sp"
        android:layout_height="90sp"
        android:layout_margin="30sp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="Sample 1"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toStartOf="@id/choice2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hr" />

    <Button
        android:id="@+id/choice2"
        android:layout_width="0sp"
        android:layout_height="90sp"
        android:layout_margin="30sp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="Sample 2"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/choice1"
        app:layout_constraintTop_toBottomOf="@id/hr" />

    <!-- BOTTOM ROW CHOICES -->

    <Button
        android:id="@+id/choice3"
        android:layout_width="0sp"
        android:layout_height="90sp"
        android:layout_margin="30sp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="Sample 3"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toStartOf="@id/choice4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/choice1" />

    <Button
        android:id="@+id/choice4"
        android:layout_width="0sp"
        android:layout_height="90sp"
        android:layout_margin="30sp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="Sample 4"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/choice3"
        app:layout_constraintTop_toBottomOf="@id/choice2" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/botbar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#2A032A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/homebtn"
            android:layout_width="0sp"
            android:layout_height="50sp"
            android:layout_marginStart="40sp"
            android:backgroundTint="#AD00FF"
            android:text="X"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/statsbtn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/hometxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="HOME"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/homebtn"
            app:layout_constraintStart_toStartOf="@id/homebtn"
            app:layout_constraintTop_toBottomOf="@id/homebtn" />


        <Button
            android:id="@+id/statsbtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="40sp"
            android:backgroundTint="#AD00FF"
            android:text="X"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/settingbtn"
            app:layout_constraintStart_toEndOf="@id/homebtn"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/gallerytxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="GALLERY"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/statsbtn"
            app:layout_constraintStart_toStartOf="@id/statsbtn"
            app:layout_constraintTop_toBottomOf="@id/homebtn" />

        <Button
            android:id="@+id/settingbtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="40sp"
            android:layout_marginEnd="40sp"
            android:backgroundTint="#AD00FF"
            android:text="X"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/statsbtn"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/settingtxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="SETTING"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/settingbtn"
            app:layout_constraintStart_toStartOf="@id/settingbtn"
            app:layout_constraintTop_toBottomOf="@id/homebtn" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>