<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2A0D1F"
    tools:context=".MainActivity">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#A0A0A0"
        android:backgroundTint="#2F082F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/AniGuess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="@string/title"
            android:textColor="#AD00FF"
            android:textSize="25sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- CENTER IMAGE -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/main"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topbar" />


    <!-- PLAY BUTTON -->
    <Button
        android:id="@+id/playbtn"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:layout_marginTop="30dp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="@string/PlayButton"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageView" />


    <!-- DIFFICULTY TEXT -->
    <TextView
        android:id="@+id/difftxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="15dp"
        android:fontFamily="@font/aldrich"
        android:text="@string/difficulty"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/playbtn" />


    <!-- DIFFICULTY BUTTONS -->
    <Button
        android:id="@+id/easybtn"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_margin="10dp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="@string/easy"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toStartOf="@id/medbtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/difftxt" />

    <Button
        android:id="@+id/medbtn"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_margin="10dp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="@string/med"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toStartOf="@id/hardbtn"
        app:layout_constraintStart_toEndOf="@id/easybtn"
        app:layout_constraintTop_toBottomOf="@id/difftxt" />

    <Button
        android:id="@+id/hardbtn"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_margin="10dp"
        android:backgroundTint="#AD00FF"
        android:fontFamily="@font/aldrich"
        android:text="@string/hard"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/medbtn"
        app:layout_constraintTop_toBottomOf="@id/difftxt" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/placeholder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:background="#430443"
        app:layout_constraintEnd_toStartOf="@id/placeholder2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/medbtn"
        app:layout_constraintBottom_toTopOf="@id/botbar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="sample"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/placeholder2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:background="#430443"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/placeholder"
        app:layout_constraintTop_toBottomOf="@id/medbtn"
        app:layout_constraintBottom_toTopOf="@id/botbar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="sample"/>
    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- BOTTOM BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/botbar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#2F082F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/homebtn"
            android:layout_width="0sp"
            android:layout_height="50sp"
            android:layout_marginStart="40sp"
            android:backgroundTint="#AD00FF"
            android:text="X"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/statsbtn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/hometxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="HOME"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/homebtn"
            app:layout_constraintStart_toStartOf="@id/homebtn"
            app:layout_constraintTop_toBottomOf="@id/homebtn" />


        <Button
            android:id="@+id/statsbtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="40sp"
            android:backgroundTint="#AD00FF"
            android:text="X"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/settingbtn"
            app:layout_constraintStart_toEndOf="@id/homebtn"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/gallerytxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="GALLERY"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/statsbtn"
            app:layout_constraintStart_toStartOf="@id/statsbtn"
            app:layout_constraintTop_toBottomOf="@id/homebtn" />

        <Button
            android:id="@+id/settingbtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="40sp"
            android:layout_marginEnd="40sp"
            android:backgroundTint="#AD00FF"
            android:text="X"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/statsbtn"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/settingtxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aldrich"
            android:text="SETTING"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/settingbtn"
            app:layout_constraintStart_toStartOf="@id/settingbtn"
            app:layout_constraintTop_toBottomOf="@id/homebtn" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>